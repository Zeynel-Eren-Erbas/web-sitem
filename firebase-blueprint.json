{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["title", "description"]
    },
    "Message": {
      "title": "Message",
      "description": "A contact form message",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "email", "message"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application (Admin)",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["admin", "user"] },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["role", "email"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Portfolio projects"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Contact form messages"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User roles and data"
    }
  }
}
